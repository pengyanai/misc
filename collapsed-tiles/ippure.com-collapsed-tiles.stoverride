name: IPPure Collapsed Tiles
icon: https://ippure.com/logo.png
desc: >
  通过IPPure.com展示是否原生IP。

tiles:
  - name: IPPure-IP-Info
    title: IP Info
    icon: https://ippure.com/logo.png
    collapsed: true
    url: https://ippure.com
  - name: IPPure-IP-Fraud-Score
    title: Fraud Score
    icon: https://ippure.com/logo.png
    collapsed: true
    url: https://ippure.com
  - name: IPPure-IP-Native-Check
    title: IP Native
    icon: https://ippure.com/logo.png
    collapsed: true
    url: https://ippure.com

script-providers:
  IPPure-IP-Info:
    url: https://fastly.jsdelivr.net/gh/StashNetworks/misc@main/collapsed-tiles/script/ippure-ip-info.js
    path: ippure/ip-info.js
  IPPure-IP-Fraud-Score:
    url: https://fastly.jsdelivr.net/gh/StashNetworks/misc@main/collapsed-tiles/script/ippure-ip-fraud-score.js
    path: ippure/ip-fraud-score.js
  IPPure-IP-Native-Check:
    url: https://fastly.jsdelivr.net/gh/StashNetworks/misc@main/collapsed-tiles/script/ippure-ip-native-check.js
    path: ippure/ip-native-check.js
