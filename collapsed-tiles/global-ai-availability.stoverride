    url: https://fastly.jsdelivr.net/gh/pengyanai/misc@main/collapsed-tiles/script/grok.js
  Gemini-Check:
    url: https://fastly.jsdelivr.net/gh/pengyanai/misc@main/collapsed-tiles/script/gemini.js
