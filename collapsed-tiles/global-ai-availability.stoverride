name: Global Availability Pack
desc: >
  Quick checks for AI and streaming service availability and exit region.
  AI tiles first (same order as ai-availability), then streaming (same as streaming pack).
  Same bundle as global.stoverride; kept under this filename for older install links.

tiles:
  - name: ChatGPT-Check
    title: ChatGPT
    icon: https://fastly.jsdelivr.net/gh/StashNetworks/misc@main/collapsed-tiles/img/chatgpt.png
    collapsed: true
    url: https://chatgpt.com
  - name: Codex-Check
    title: Codex
    icon: https://fastly.jsdelivr.net/gh/pengyanai/misc@main/collapsed-tiles/img/codex.png
    collapsed: true
    url: https://chatgpt.com/codex
  - name: Claude-Check
    title: Claude
    icon: https://fastly.jsdelivr.net/gh/pengyanai/misc@main/collapsed-tiles/img/claude.png
    collapsed: true
    url: https://claude.ai
  - name: Grok-Check
    title: Grok
    icon: https://fastly.jsdelivr.net/gh/pengyanai/misc@main/collapsed-tiles/img/grok.png
    collapsed: true
    url: https://grok.com
  - name: Gemini-Check
    title: Gemini
    icon: https://fastly.jsdelivr.net/gh/pengyanai/misc@main/collapsed-tiles/img/gemini.png
    collapsed: true
    url: https://gemini.google.com
  - name: Copilot-Check
    title: Copilot
    icon: https://fastly.jsdelivr.net/gh/pengyanai/misc@main/collapsed-tiles/img/copilot.png
    collapsed: true
    url: https://copilot.microsoft.com
  - name: YouTube-Check
    title: YouTube
    icon: https://fastly.jsdelivr.net/gh/StashNetworks/misc@main/collapsed-tiles/img/youtube.png
    collapsed: true
    url: https://www.youtube.com
  - name: Netflix-Check
    title: Netflix
    icon: https://fastly.jsdelivr.net/gh/StashNetworks/misc@main/collapsed-tiles/img/netflix.png
    collapsed: true
    url: https://www.netflix.com
  - name: Disney-Check
    title: Disney+
    icon: https://fastly.jsdelivr.net/gh/pengyanai/misc@main/collapsed-tiles/img/disney.png
    collapsed: true
    url: https://www.disneyplus.com
  - name: Spotify-Check
    title: Spotify
    icon: https://fastly.jsdelivr.net/gh/pengyanai/misc@main/collapsed-tiles/img/spotify.png
    collapsed: true
    url: https://www.spotify.com

